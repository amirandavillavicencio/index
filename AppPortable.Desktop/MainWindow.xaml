<Window x:Class="AppPortable.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AppPortable" Height="700" Width="1200" MinHeight="500" MinWidth="900">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding IsBusy, StringFormat=Busy: {0}}" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#DDD" Padding="10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button Content="Cargar PDF" Command="{Binding LoadDocumentCommand}" Height="32" Margin="0,0,0,8"/>
                        <Button Content="Reindexar" Command="{Binding ReindexCommand}" Height="32"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Documents}" SelectedItem="{Binding SelectedDocument}" DisplayMemberPath="Title"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" BorderThickness="0,0,1,0" BorderBrush="#DDD" Padding="10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox Width="250" Height="28" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Content="Buscar" Width="90" Height="28" Command="{Binding SearchCommand}"/>
                    </StackPanel>

                    <ListView ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedResult}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Documento" DisplayMemberBinding="{Binding DocumentId}" Width="130"/>
                                <GridViewColumn Header="Páginas" DisplayMemberBinding="{Binding PageStart}" Width="60"/>
                                <GridViewColumn Header="Score" DisplayMemberBinding="{Binding Score}" Width="70"/>
                                <GridViewColumn Header="Snippet" DisplayMemberBinding="{Binding Snippet}" Width="300"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Padding="10">
                <TextBox Text="{Binding SelectedDetail}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" IsReadOnly="True"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
