<Window x:Class="AppPortable.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gabriela"
        Height="820"
        Width="1400"
        MinWidth="900"
        MinHeight="600"
        Background="#EEF1F5"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="BorderColor" Color="#D6D9DE"/>
        <SolidColorBrush x:Key="Muted" Color="#6B7280"/>
        <SolidColorBrush x:Key="PanelBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#FBFBFC"/>
        <SolidColorBrush x:Key="OkGreen" Color="#166534"/>
        <SolidColorBrush x:Key="WarnOrange" Color="#9A3412"/>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#B8BCC3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D6D9DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F7F7F8"
                BorderBrush="#D6D9DE"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="14,0">
                <Ellipse Width="10"
                         Height="10"
                         Fill="#2563EB"
                         Opacity=".75"
                         Margin="0,0,10,0"/>
                <TextBlock FontWeight="Bold"
                           Text="Gabriela"
                           Margin="0,0,8,0"/>
                <TextBlock Text="•"
                           Foreground="#9CA3AF"
                           Margin="0,0,8,0"/>
                <TextBlock x:Name="TitleStatus"
                           Text="Listo"
                           Foreground="#6B7280"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D6D9DE"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,7,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FBFBFC"
                            BorderBrush="#D6D9DE"
                            BorderThickness="0,0,0,1"
                            CornerRadius="10,10,0,0"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Documentos"
                                       FontSize="17"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Carga, OCR e indexación local"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14">

                            <Border BorderBrush="#BFD2FB"
                                    BorderThickness="2"
                                    Background="#F8FBFF"
                                    CornerRadius="10"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock x:Name="DropzoneTitle"
                                               Text="Arrastra un PDF aquí"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               TextAlignment="Center"/>
                                    <TextBlock x:Name="DropzoneSub"
                                               Text="O usa el botón Cargar PDF para seleccionar el archivo."
                                               Foreground="#6B7280"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Margin="0,5,0,0"
                                               LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <Button x:Name="BtnCargar"
                                    Content="Cargar PDF"
                                    Style="{StaticResource BtnPrimary}"
                                    Click="BtnCargar_Click"
                                    Margin="0,12,0,8"/>

                            <Button x:Name="BtnProcesar"
                                    Content="Procesar e indexar"
                                    Style="{StaticResource BtnSecondary}"
                                    IsEnabled="False"
                                    Click="BtnProcesar_Click"
                                    Margin="0,0,0,12"/>

                            <Border x:Name="DocCard"
                                    Visibility="Collapsed"
                                    Background="#FAFAFA"
                                    BorderBrush="#D6D9DE"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="DocName"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="Origen: carpeta seleccionada"
                                                       Foreground="#6B7280"
                                                       FontSize="11"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <Border x:Name="DocBadge"
                                                Grid.Column="1"
                                                CornerRadius="999"
                                                Padding="7,4"
                                                VerticalAlignment="Top"
                                                Background="#FFEDD5">
                                            <TextBlock x:Name="DocBadgeText"
                                                       Text="Pendiente"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="#9A3412"/>
                                        </Border>
                                    </Grid>

                                    <UniformGrid Columns="2" Margin="0,8,0,0">
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="Páginas"
                                                       Foreground="#6B7280"
                                                       FontSize="11"/>
                                            <TextBlock x:Name="DocPages"
                                                       Text="–"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="Motor OCR"
                                                       Foreground="#6B7280"
                                                       FontSize="11"/>
                                            <TextBlock Text="Tesseract"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="Chunks"
                                                       Foreground="#6B7280"
                                                       FontSize="11"/>
                                            <TextBlock x:Name="DocChunks"
                                                       Text="–"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Índice"
                                                       Foreground="#6B7280"
                                                       FontSize="11"/>
                                            <TextBlock Text="SQLite FTS5"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border x:Name="ProgressCard"
                                    Visibility="Collapsed"
                                    Background="#FCFCFD"
                                    BorderBrush="#D6D9DE"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock x:Name="ProgressLabel"
                                                   FontWeight="SemiBold"
                                                   Text="Iniciando..."/>
                                        <TextBlock x:Name="ProgressPct"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#6B7280"/>
                                    </Grid>
                                    <ProgressBar x:Name="MainProgress"
                                                 Height="10"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="0"
                                                 Foreground="#3B82F6"
                                                 Background="#E5E7EB"
                                                 Margin="0,0,0,8"/>
                                    <TextBlock Text="Extrayendo texto, OCR y preparando chunks."
                                               Foreground="#6B7280"
                                               FontSize="11"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <UniformGrid x:Name="KpiRow"
                                         Columns="3"
                                         Visibility="Collapsed">
                                <Border Style="{StaticResource Card}" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="Págs. OCR"
                                                   Foreground="#6B7280"
                                                   FontSize="11"/>
                                        <TextBlock x:Name="KpiPages"
                                                   Text="0"
                                                   FontSize="20"
                                                   FontWeight="ExtraBold"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="Chunks"
                                                   Foreground="#6B7280"
                                                   FontSize="11"/>
                                        <TextBlock x:Name="KpiChunks"
                                                   Text="0"
                                                   FontSize="20"
                                                   FontWeight="ExtraBold"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Índice"
                                                   Foreground="#6B7280"
                                                   FontSize="11"/>
                                        <TextBlock x:Name="KpiIndex"
                                                   Text="–"
                                                   FontSize="20"
                                                   FontWeight="ExtraBold"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D6D9DE"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="7,0,7,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FBFBFC"
                            BorderBrush="#D6D9DE"
                            BorderThickness="0,0,0,1"
                            CornerRadius="10,10,0,0"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Búsqueda"
                                       FontSize="17"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Nombre, RUT/RUC, folio o palabra clave"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="14">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="#B8BCC3"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Margin="0,0,8,0"
                                    Background="White">
                                <TextBox x:Name="SearchBox"
                                         BorderThickness="0"
                                         Height="36"
                                         Padding="10,0"
                                         VerticalContentAlignment="Center"
                                         Background="Transparent"
                                         KeyDown="SearchBox_KeyDown"/>
                            </Border>

                            <Button Grid.Column="1"
                                    Content="Buscar"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource BtnPrimary}"
                                    Click="BtnBuscar_Click"/>

                            <Button Grid.Column="2"
                                    Content="Limpiar"
                                    Style="{StaticResource BtnSecondary}"
                                    Click="BtnLimpiar_Click"/>
                        </Grid>

                        <TextBlock x:Name="ResultsLabel"
                                   Text="Escribe un término y presiona Buscar."
                                   Foreground="#6B7280"
                                   FontSize="11"
                                   Margin="0,0,0,10"/>

                        <Border BorderBrush="#D6D9DE"
                                BorderThickness="1"
                                CornerRadius="10"
                                Height="560">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="#F8FAFC"
                                        BorderBrush="#D6D9DE"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="10,10,0,0">
                                    <Grid Margin="12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="1.8*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Documento"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   Foreground="#475569"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="Pág."
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   Foreground="#475569"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="Score"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   Foreground="#475569"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="Fragmento"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="11"
                                                   Foreground="#475569"/>
                                    </Grid>
                                </Border>

                                <ListView x:Name="ResultsList"
                                          Grid.Row="1"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          SelectionChanged="ResultsList_SelectionChanged"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="12,10"/>
                                            <Setter Property="BorderBrush" Value="#EDF0F3"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EEF5FF"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F8FBFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="1.8*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DocumentName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Top"
                                                           FontSize="12"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding PageNumber}"
                                                           VerticalAlignment="Top"
                                                           FontSize="12"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Score}"
                                                           VerticalAlignment="Top"
                                                           FontSize="12"
                                                           Foreground="#6B7280"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Snippet}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"
                                                           Foreground="#374151"
                                                           LineHeight="17"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D6D9DE"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="7,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FBFBFC"
                            BorderBrush="#D6D9DE"
                            BorderThickness="0,0,0,1"
                            CornerRadius="10,10,0,0"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Detalle"
                                       FontSize="17"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Vista completa del texto extraído por página"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="14">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="DetailDocName"
                                           Text="–"
                                           FontWeight="Bold"
                                           FontSize="13"/>
                                <TextBlock x:Name="DetailPageInfo"
                                           Text="Selecciona un resultado"
                                           Foreground="#6B7280"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="BtnExportar"
                                        Content="Exportar resultados"
                                        Style="{StaticResource BtnSecondary}"
                                        IsEnabled="False"
                                        Click="BtnExportar_Click"
                                        Margin="0,0,8,0"/>

                                <Button x:Name="BtnExportarDocumentoOcrMd"
                                        Content="Exportar OCR completo a MD"
                                        Style="{StaticResource BtnSecondary}"
                                        IsEnabled="False"
                                        Click="BtnExportarDocumentoOcrMd_Click"
                                        Margin="0,0,8,0"/>

                                <Button x:Name="BtnIrPagina"
                                        Content="Ir a la página"
                                        Style="{StaticResource BtnPrimary}"
                                        IsEnabled="False"
                                        Click="BtnIrPagina_Click"/>
                            </StackPanel>
                        </Grid>

                        <Border BorderBrush="#D6D9DE"
                                BorderThickness="1"
                                CornerRadius="10"
                                Height="630">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FCFCFC" Offset="0"/>
                                    <GradientStop Color="#F8F8F8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <ScrollViewer Padding="18" VerticalScrollBarVisibility="Auto">
                                <Border Background="White"
                                        BorderBrush="#D7DBE0"
                                        BorderThickness="1"
                                        Padding="34,38"
                                        MinHeight="640"
                                        MaxWidth="560"
                                        HorizontalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000"
                                                          Opacity="0.07"
                                                          BlurRadius="20"
                                                          ShadowDepth="8"/>
                                    </Border.Effect>

                                    <StackPanel>
                                        <TextBlock x:Name="DetailPageNum"
                                                   Text="Selecciona un resultado para ver el contenido"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#6B7280"
                                                   FontSize="11"/>
                                        <TextBlock x:Name="DetailContent"
                                                   TextWrapping="Wrap"
                                                   FontSize="13"
                                                   Foreground="#374151"
                                                   LineHeight="21"
                                                   TextAlignment="Justify"/>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FAFAFA"
                BorderBrush="#D6D9DE"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="StatusLeft"
                           VerticalAlignment="Center"
                           Text="Estado: listo • almacenamiento local OK"
                           FontSize="11"
                           Foreground="#4B5563"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="StatusRight"
                               Text="Inactivo"
                               FontSize="11"
                               Foreground="#6B7280"
                               Margin="0,0,8,0"/>
                    <ProgressBar x:Name="StatusProgress"
                                 Width="140"
                                 Height="9"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="#60A5FA"
                                 Background="#E5E7EB"
                                 Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>