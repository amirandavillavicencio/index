<Window x:Class="AppPortable.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppPortable" Height="700" Width="1200" MinHeight="480" MinWidth="900">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#F3F3F3" BorderBrush="#D0D0D0" BorderThickness="1,1,1,0" Padding="10,6">
            <TextBlock Text="Estado: listo para fase 2" />
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Documentos" Margin="10" Grid.Column="0">
                <ListBox>
                    <ListBoxItem Content="(Sin documentos cargados)" />
                </ListBox>
            </GroupBox>

            <GroupBox Header="Búsqueda" Margin="0,10,10,10" Grid.Column="1">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBox Height="30" VerticalContentAlignment="Center" Text="Escribe para buscar..." />
                    <Border Grid.Row="2" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="8">
                        <TextBlock Text="Resultados de búsqueda aparecerán aquí en fases posteriores."
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top" />
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Header="Detalle" Margin="0,10,10,10" Grid.Column="2">
                <Border Margin="10" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="8">
                    <TextBlock Text="Selecciona un documento o resultado para ver detalles."
                               TextWrapping="Wrap"
                               VerticalAlignment="Top" />
                </Border>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
